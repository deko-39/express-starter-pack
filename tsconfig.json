{
  "compilerOptions": {
    "outDir": "dist",
    "sourceMap": true,
    "target": "esnext",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "strictPropertyInitialization": false,
    "strict": true,
    "incremental": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "baseUrl": "./",
    "paths": {
      "@src/*": ["./src/*"]
    }
  },
  "include": [
    "src/@types/*",
    "src/**/*.ts",
    "tests/**/*.ts",
    "importer/**/*.ts",
    "prisma/**/*.ts",
    "prisma-mobile/**/*.ts",
    "prisma-pg/**/*.ts",
    "cron/**/*.ts",
    "queue/**/*.ts",
    "scripts/**/*.ts",
    "packages/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "packages/**/dist"]
}
